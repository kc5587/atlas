{
  "compilerOptions": {
    "target": "ES2022", "module": "ESNext", "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true, "skipLibCheck": true, "verbatimModuleSyntax": true,
    "isolatedModules": true, "types": ["svelte", "vite/client"]
  },
  "include": ["src", "tests"]
}
